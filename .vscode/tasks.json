{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "Install dependencies",
			"command": "npm install",
			"group": "build",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"type": "shell",
			"runOn": "folderOpen",
			"label": "Start Development Server",
			"command": "npm run dev",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Final Typecheck Validation",
			"type": "shell",
			"command": "npm run typecheck; Write-Output \"TYPECHECK_EXIT=$LASTEXITCODE\"; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }",
			"isBackground": false
		}
	]
}