{
  "name": "MindMate - Overdue Check Daily",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "cronExpression": "0 18 * * *"
        }
      },
      "id": "schedule-trigger-overdue",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        320,
        280
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.MINDMATE_BASE_URL + '/api/notifications/trigger-overdue-check'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.MINDMATE_CRON_AUTH_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "options": {
          "timeout": 60000
        }
      },
      "id": "http-request-overdue",
      "name": "Trigger Overdue Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        620,
        280
      ]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Trigger Overdue Check",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false,
  "meta": {
    "templateCredsSetupCompleted": true
  }
